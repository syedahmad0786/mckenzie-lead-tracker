# =====================================================================
# McKenzie Lead Tracker — Phase 1 (Airtable-only)
# Copy to .env.local for development. Set the same keys in Vercel for prod.
#
#   vercel env pull .env.local --environment=production
# =====================================================================

# ----- Airtable (source of truth) -----
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# ----- n8n (orchestration + Slack delivery) -----
N8N_BASE_URL=https://n8n.aimanagingservices.com
N8N_API_KEY=
N8N_TRIGGER_SECRET=

# Webhook URLs the app fires to (each n8n workflow exposes one)
N8N_STATUS_CHANGE_WEBHOOK=
N8N_NEW_LEAD_WEBHOOK=
N8N_ORDER_PLACED_WEBHOOK=
N8N_ERROR_ALERT_WEBHOOK=
N8N_DAILY_DIGEST_WEBHOOK=
N8N_WEEKLY_DIGEST_WEBHOOK=

# ----- Instantly + Typeform (inbound webhook secrets) -----
INSTANTLY_WEBHOOK_SECRET=
TYPEFORM_WEBHOOK_SECRET=

# ----- Make.com (only needed for ./scripts/make/inventory.sh; NOT used at runtime) -----
# Token belongs to MA team 285569 (us2 zone, org 2518043). Lujan owns the workspace.
MAKE_API_TOKEN=
MAKE_TEAM_ID=285569
MAKE_ZONE=us2

# ----- App self-reference -----
NEXT_PUBLIC_APP_URL=https://tracker.modern-amenities.com

# ----- Active client (Phase 1 single-tenant; Phase 2 reads from clients table) -----
ACTIVE_CLIENT_ID=mckenzie

# ----- Email + Anthropic deferred to v2 ("will get emails later") -----
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=
# ANTHROPIC_API_KEY=

# ----- Supabase deferred to Phase 2 (see phase-2-supabase/README.md) -----
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRON_SECRET=
